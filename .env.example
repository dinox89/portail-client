# App
NEXT_PUBLIC_ADMIN_USER_ID=admin-dinobenoit
ADMIN_EMAIL=dinobenoit892@gmail.com
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me
REALTIME_JWT_SECRET=change-me
ALLOWED_ORIGINS=http://localhost:3000
PORT=3000

# Database (PostgreSQL)
# Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Optional: direct endpoint (recommended for Prisma migrations if DATABASE_URL uses a pooler)
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Optional realtime tuning
NEXT_PUBLIC_SOCKET_RECONNECT_ATTEMPTS=10
NEXT_PUBLIC_SOCKET_RECONNECT_DELAY=500
NEXT_PUBLIC_SOCKET_RECONNECT_DELAY_MAX=10000
NEXT_PUBLIC_SOCKET_TIMEOUT=8000
NEXT_PUBLIC_PERF_DELAY=0

# Optional Prisma migrate retry tuning (network/cold start)
PRISMA_MIGRATE_DEPLOY_RETRIES=8
PRISMA_MIGRATE_DEPLOY_DELAY_MS=1500
PRISMA_MIGRATE_DEPLOY_DELAY_MAX_MS=15000
